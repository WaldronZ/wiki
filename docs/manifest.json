      "output": "",
      "mutates": false
    },
    {
      "id": "apply_inbox",
      "kind": "writeback",
      "label": "Apply candidate inbox CSV",
      "command": "python3 scripts/apply_inbox_items.py docs --input <candidate_csv> --write",
      "output": "docs/inbox.csv",
      "mutates": true
    },
    {
      "id": "apply_metadata",
      "kind": "writeback",
      "label": "Apply edited metadata CSV",
