      "label": "Apply status workflow JSON",
      "command": "python3 scripts/apply_status_workflow.py docs --input <taxonomy_status_workflow.json> --write",
      "output": "docs/guides/taxonomy.json",
      "mutates": true
    },
    {
      "id": "apply_governance_policy_dry_run",
