    },
    {
      "id": "quality_gate",
      "kind": "check",
      "label": "Quality gate",
      "command": "python3 scripts/check_quality.py docs",
      "output": "",
      "mutates": false
    },
    {
      "id": "strict_validate",
      "kind": "check",
      "label": "Strict validation",
      "command": "python3 scripts/validate_wiki.py docs --strict-taxonomy",
      "output": "",
      "mutates": false
    },
    {
      "id": "apply_metadata_dry_run",
