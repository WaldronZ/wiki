      "description": "Turn overloaded or sparse taxonomy buckets into project tasks before changing labels.",
      "steps": [
        "taxonomy_balance_project",
        "taxonomy_actions_project",
        "quality_gate"
      ]
    },
    {
      "id": "weekly_action_review",
