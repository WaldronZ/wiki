{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/autopaperreader/taxonomy.schema.json",
  "title": "AutoPaperReader taxonomy configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional editor schema reference."
    },
    "label_aliases": {
      "type": "object",
      "description": "Map alternate labels to canonical taxonomy labels.",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "role_order": {
      "$ref": "#/$defs/non_empty_string_list"
    },
    "status_values": {
      "$ref": "#/$defs/non_empty_string_list"
    },
    "reading_stage_values": {
      "$ref": "#/$defs/non_empty_string_list"
    },
    "review_stage_values": {
      "$ref": "#/$defs/non_empty_string_list"
    },
    "active_status_workflow": {
      "type": "string",
      "minLength": 1,
      "description": "Name of the default workflow in status_workflows."
    },
    "status_workflows": {
      "type": "object",
      "description": "Named workflow presets for status, reading stage, and review stage values.",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "status_values": {
            "$ref": "#/$defs/non_empty_string_list"
          },
          "reading_stage_values": {
            "$ref": "#/$defs/non_empty_string_list"
          },
          "review_stage_values": {
            "$ref": "#/$defs/non_empty_string_list"
          }
        },
        "required": [
          "status_values",
          "reading_stage_values",
          "review_stage_values"
        ]
      }
    },
    "shared_views": {
      "type": "array",
      "description": "Repository-shared saved filters for index/library views.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "page": {
            "type": "string",
            "enum": ["all", "index", "library"]
          },
          "state": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": false,
            "properties": {
              "q": {"$ref": "#/$defs/filter_value"},
              "domain": {"$ref": "#/$defs/filter_value"},
              "track": {"$ref": "#/$defs/filter_value"},
              "problem": {"$ref": "#/$defs/filter_value"},
              "line": {"$ref": "#/$defs/filter_value"},
              "role": {"$ref": "#/$defs/filter_value"},
              "workflow": {"$ref": "#/$defs/filter_value"},
              "topic": {"$ref": "#/$defs/filter_value"},
              "method": {"$ref": "#/$defs/filter_value"},
              "status": {"$ref": "#/$defs/filter_value"},
              "stage": {"$ref": "#/$defs/filter_value"},
              "reviewStage": {"$ref": "#/$defs/filter_value"},
              "review": {"$ref": "#/$defs/filter_value"},
              "code": {"$ref": "#/$defs/filter_value"},
              "importance": {"$ref": "#/$defs/filter_value"},
              "sort": {"$ref": "#/$defs/filter_value"},
              "size": {"$ref": "#/$defs/filter_value"},
              "page": {"$ref": "#/$defs/filter_value"}
            }
          }
        },
        "required": ["name", "state"]
      }
    },
    "bulk_presets": {
      "type": "array",
      "description": "Configurable bulk metadata presets for library.html.",
      "items": {"$ref": "#/$defs/bulk_preset"}
    },
    "research_line_owners": {
      "type": "object",
      "description": "Optional ownership metadata for research lines, used by dashboards and coverage review queues.",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "owner": {"type": "string", "minLength": 1},
          "team": {"type": "string", "minLength": 1},
          "cadence": {"type": "string", "minLength": 1},
          "note": {"type": "string", "minLength": 1}
        },
        "minProperties": 1
      }
    },
    "label_definitions": {
      "type": "object",
      "description": "Optional controlled-vocabulary definitions for taxonomy labels, grouped by metadata field.",
      "additionalProperties": false,
      "properties": {
        "domains": {"$ref": "#/$defs/label_definition_map"},
        "tracks": {"$ref": "#/$defs/label_definition_map"},
        "problems": {"$ref": "#/$defs/label_definition_map"},
        "topics": {"$ref": "#/$defs/label_definition_map"},
        "methods": {"$ref": "#/$defs/label_definition_map"},
        "research_line": {"$ref": "#/$defs/label_definition_map"},
        "line_role": {"$ref": "#/$defs/label_definition_map"},
        "status": {"$ref": "#/$defs/label_definition_map"},
        "reading_stage": {"$ref": "#/$defs/label_definition_map"},
        "review_stage": {"$ref": "#/$defs/label_definition_map"}
      }
    },
    "governance_policy": {
      "type": "object",
      "description": "Configurable governance thresholds for quality, taxonomy actions, balance, and coverage reports.",
      "additionalProperties": false,
      "properties": {
        "taxonomy_load": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min_structure_labels": {"type": "integer", "minimum": 0},
            "min_tags": {"type": "integer", "minimum": 0},
            "max_tags": {"type": "integer", "minimum": 0},
            "max_methods": {"type": "integer", "minimum": 0}
          }
        },
        "taxonomy_actions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "singleton_max_count": {"type": "integer", "minimum": 0},
            "watch_share": {"type": "number", "minimum": 0},
            "watch_min_count": {"type": "integer", "minimum": 0},
            "split_share": {"type": "number", "minimum": 0},
            "split_min_count": {"type": "integer", "minimum": 0}
          }
        },
        "taxonomy_balance": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "high_score_below": {"type": "integer", "minimum": 0},
            "medium_score_below": {"type": "integer", "minimum": 0},
            "singleton_medium_count": {"type": "integer", "minimum": 0},
            "unused_medium_count": {"type": "integer", "minimum": 0}
          }
        },
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "high_score_below": {"type": "integer", "minimum": 0},
            "medium_score_below": {"type": "integer", "minimum": 0},
            "missing_high_min": {"type": "integer", "minimum": 0}
          }
        }
      }
    }
  },
  "$defs": {
    "non_empty_string_list": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "filter_value": {
      "type": ["string", "number", "boolean"],
      "description": "URL query state value; objects and arrays are not allowed."
    },
    "label_definition_map": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "description": {"type": "string", "minLength": 1},
          "owner": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["active", "watch", "deprecated"]},
          "note": {"type": "string", "minLength": 1}
        },
        "minProperties": 1
      }
    },
    "bulk_preset": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1},
        "description": {"type": "string"},
        "fields": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": false,
          "properties": {
            "status": {"$ref": "#/$defs/preset_value_or_candidates"},
            "reading_stage": {"$ref": "#/$defs/preset_value_or_candidates"},
            "review_stage": {"$ref": "#/$defs/preset_value_or_candidates"},
            "next_review_days": {"type": "integer", "minimum": 0},
            "importance": {"oneOf": [{"type": "integer", "minimum": 1, "maximum": 5}, {"type": "string", "pattern": "^[1-5]$"}]},
            "research_line": {"$ref": "#/$defs/preset_value_or_candidates"},
            "line_role": {"$ref": "#/$defs/preset_value_or_candidates"},
            "domains": {"$ref": "#/$defs/preset_value_or_candidates"},
            "tracks": {"$ref": "#/$defs/preset_value_or_candidates"},
            "problems": {"$ref": "#/$defs/preset_value_or_candidates"},
            "topics": {"$ref": "#/$defs/preset_value_or_candidates"},
            "methods": {"$ref": "#/$defs/preset_value_or_candidates"},
            "list_mode": {"type": "string", "enum": ["replace", "append", "remove"]}
          }
        }
      },
      "required": ["id", "label", "fields"]
    },
    "preset_value_or_candidates": {
      "oneOf": [
        {"type": "string", "minLength": 1},
        {"$ref": "#/$defs/non_empty_string_list"}
      ]
    }
  }
}
