        "status": "active"
      }
    },
    "topics": {
      "Attention Kernels": {
        "description": "Attention implementation, scheduling, and memory-layout techniques used by LLM inference systems.",
        "owner": "kernel-owner",
        "status": "active"
      },
      "Parallel Decoding": {
        "description": "Methods that generate or verify multiple tokens per step rather than strictly left-to-right one-token decoding.",
        "owner": "decoding-owner",
        "status": "active"
      },
      "Speculative Decoding": {
        "description": "Draft-and-verify decoding methods that preserve target-model output distribution while improving latency.",
        "owner": "decoding-owner",
        "status": "active"
      }
    },
    "methods": {
      "FlashAttention": {
        "description": "IO-aware exact attention kernel family that reduces HBM traffic with tiling and online softmax.",
        "owner": "kernel-owner",
        "status": "active"
      },
      "Speculative Decoding": {
        "description": "Use a draft process and acceptance rule to accelerate autoregressive generation.",
        "owner": "decoding-owner",
        "status": "active"
      }
