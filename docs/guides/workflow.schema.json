{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/autopaperreader/workflow.schema.json",
  "title": "AutoPaperReader Workflow Audit",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "generated_at",
    "count",
    "active_status_workflow",
    "workflow_count",
    "workflows",
    "active_unconfigured",
    "shared_workflow_views",
    "recommendations",
    "commands"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "description": "ISO timestamp when the workflow audit payload was generated."
    },
    "count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of reports represented by the wiki."
    },
    "active_status_workflow": {
      "type": "string",
      "minLength": 1
    },
    "workflow_count": {
      "type": "integer",
      "minimum": 0
    },
    "workflows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workflow"
      }
    },
    "active_unconfigured": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/unconfigured_value"
      }
    },
    "shared_workflow_views": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/shared_workflow_view"
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "definition": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "owner": { "type": "string" },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "watch",
            "deprecated"
          ]
        },
        "note": { "type": "string" }
      },
      "additionalProperties": true
    },
    "status_value": {
      "type": "object",
      "required": [
        "value",
        "count",
        "configured",
        "href"
      ],
      "properties": {
        "value": { "type": "string" },
        "count": { "type": "integer", "minimum": 0 },
        "configured": { "type": "boolean" },
        "definition": { "$ref": "#/$defs/definition" },
        "definition_status": { "type": "string" },
        "description": { "type": "string" },
        "owner_name": { "type": "string" },
        "href": { "type": "string" },
        "slugs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "status_field": {
      "type": "object",
      "required": [
        "field",
        "label",
        "configured_count",
        "used_configured_count",
        "defined_count",
        "deprecated_count",
        "empty_count",
        "empty_slugs",
        "values",
        "unconfigured"
      ],
      "properties": {
        "field": {
          "type": "string",
          "enum": [
            "status",
            "reading_stage",
            "review_stage"
          ]
        },
        "label": { "type": "string" },
        "configured_count": { "type": "integer", "minimum": 0 },
        "used_configured_count": { "type": "integer", "minimum": 0 },
        "defined_count": { "type": "integer", "minimum": 0 },
        "deprecated_count": { "type": "integer", "minimum": 0 },
        "empty_count": { "type": "integer", "minimum": 0 },
        "empty_slugs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "values": {
          "type": "array",
          "items": { "$ref": "#/$defs/status_value" }
        },
        "unconfigured": {
          "type": "array",
          "items": { "$ref": "#/$defs/status_value" }
        }
      },
      "additionalProperties": true
    },
    "workflow": {
      "type": "object",
      "required": [
        "name",
        "active",
        "status_values",
        "reading_stage_values",
        "review_stage_values",
        "fields",
        "unconfigured_total",
        "empty_total",
        "definition_total",
        "deprecated_total",
        "board_href",
        "library_href"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "active": { "type": "boolean" },
        "status_values": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reading_stage_values": {
          "type": "array",
          "items": { "type": "string" }
        },
        "review_stage_values": {
          "type": "array",
          "items": { "type": "string" }
        },
        "fields": {
          "type": "object",
          "required": [
            "status",
            "reading_stage",
            "review_stage"
          ],
          "properties": {
            "status": { "$ref": "#/$defs/status_field" },
            "reading_stage": { "$ref": "#/$defs/status_field" },
            "review_stage": { "$ref": "#/$defs/status_field" }
          },
          "additionalProperties": true
        },
        "unconfigured_total": { "type": "integer", "minimum": 0 },
        "empty_total": { "type": "integer", "minimum": 0 },
        "definition_total": { "type": "integer", "minimum": 0 },
        "deprecated_total": { "type": "integer", "minimum": 0 },
        "board_href": { "type": "string" },
        "library_href": { "type": "string" }
      },
      "additionalProperties": true
    },
    "unconfigured_value": {
      "allOf": [
        { "$ref": "#/$defs/status_value" },
        {
          "type": "object",
          "required": [
            "field",
            "label",
            "slugs"
          ],
          "properties": {
            "field": {
              "type": "string",
              "enum": [
                "status",
                "reading_stage",
                "review_stage"
              ]
            },
            "label": { "type": "string" },
            "slugs": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      ]
    },
    "shared_workflow_view": {
      "type": "object",
      "required": [
        "name",
        "page",
        "workflow",
        "href",
        "state"
      ],
      "properties": {
        "name": { "type": "string" },
        "page": {
          "type": "string",
          "enum": [
            "all",
            "index",
            "library"
          ]
        },
        "workflow": { "type": "string" },
        "href": { "type": "string" },
        "state": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          }
        }
      },
      "additionalProperties": true
    }
  }
}
