{
  "description": "CSV contract for docs/inbox.csv candidate paper intake.",
  "delimiter": ",",
  "required": [
    "title",
    "link"
  ],
  "recommended": [
    "id",
    "status",
    "priority",
    "tags",
    "note",
    "added_at"
  ],
  "fields": {
    "id": {"type": "string", "required": false, "description": "Stable optional candidate id."},
    "title": {"type": "string", "required": true, "description": "Paper title or short name."},
    "link": {"type": "string", "required": true, "description": "arXiv, OpenReview, DOI, project, or PDF link."},
    "status": {"type": "string", "required": false, "enum": ["queued", "triaged", "reading", "done", "skipped"]},
    "priority": {"type": "string", "required": false, "enum": ["high", "normal", "medium", "low"]},
    "tags": {"type": "list", "required": false, "separator": ";"},
    "note": {"type": "string", "required": false},
    "added_at": {"type": "date", "required": false}
  },
  "aliases": {
    "title": ["name", "paper"],
    "link": ["url", "arxiv_url"],
    "note": ["notes"],
    "added_at": ["created_at"],
    "tags": ["topics"]
  }
}
