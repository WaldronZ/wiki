{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/autopaperreader/bootstrap_bundle.schema.json",
  "title": "AutoPaperReader desktop bootstrap bundle",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "generated_at": {"type": "string"},
    "report_dir": {"type": "string", "minLength": 1},
    "source_catalog": {"$ref": "#/$defs/source_catalog"},
    "summary": {"$ref": "#/$defs/summary"},
    "files": {
      "type": "array",
      "items": {"$ref": "#/$defs/file"}
    },
    "missing": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "errors": {
      "type": "array",
      "items": {"$ref": "#/$defs/error"}
    }
  },
  "required": [
    "generated_at",
    "report_dir",
    "source_catalog",
    "summary",
    "files",
    "missing",
    "errors"
  ],
  "$defs": {
    "source_catalog": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "href": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string"},
        "count": {"type": ["integer", "null"], "minimum": 0},
        "data_file_count": {"type": ["integer", "null"], "minimum": 0},
        "recommended_bootstrap_files": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      },
      "required": ["href", "generated_at", "count", "data_file_count", "recommended_bootstrap_files"]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "file_count": {"type": "integer", "minimum": 0},
        "payload_count": {"type": "integer", "minimum": 0},
        "missing_count": {"type": "integer", "minimum": 0},
        "error_count": {"type": "integer", "minimum": 0},
        "total_size_bytes": {"type": "integer", "minimum": 0},
        "mode": {
          "type": "string",
          "enum": ["recommended", "explicit", "all_data"]
        }
      },
      "required": ["file_count", "payload_count", "missing_count", "error_count", "total_size_bytes", "mode"]
    },
    "file": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "href": {"type": "string", "minLength": 1},
        "description": {"type": "string"},
        "consumers": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "exists": {"type": "boolean"},
        "size_bytes": {"type": "integer", "minimum": 0},
        "sha256": {
          "type": "string",
          "pattern": "^$|^[0-9a-f]{64}$"
        },
        "top_level_keys": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "collections": {
          "type": "array",
          "items": {"$ref": "#/$defs/collection"}
        },
        "declared_count": {"type": ["integer", "null"], "minimum": 0},
        "generated_at": {"type": "string"},
        "error": {"type": "string"},
        "payload": true
      },
      "required": [
        "href",
        "description",
        "consumers",
        "exists",
        "size_bytes",
        "sha256",
        "top_level_keys",
        "collections",
        "declared_count",
        "generated_at",
        "error"
      ]
    },
    "collection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key": {"type": "string", "minLength": 1},
        "type": {
          "type": "string",
          "enum": ["list", "object"]
        },
        "count": {"type": "integer", "minimum": 0}
      },
      "required": ["key", "type", "count"]
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "href": {"type": "string", "minLength": 1},
        "error": {"type": "string"}
      },
      "required": ["href", "error"]
    }
  }
}
